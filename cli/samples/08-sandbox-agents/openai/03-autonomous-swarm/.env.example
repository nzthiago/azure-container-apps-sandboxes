# Autonomous Swarm — zero AOAI-key demo.
# The launcher reads samples/.env at the repo root, so this file is
# reference-only. Populate samples/.env once for all 08-sandbox-agents demos.
#
# Notice: there is NO AZURE_OPENAI_API_KEY field. Authentication to AOAI
# is via Entra ID / Managed Identity. The supervisor running inside the
# orchestrator sandbox uses the sandbox group's SystemAssigned MI to call
# AOAI; no key is ever written into the sandbox.

# --- AOAI (required) -------------------------------------------------------

AZURE_OPENAI_ENDPOINT=https://<your-aoai-account>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Full ARM resource id of your AOAI account. If omitted, the launcher
# attempts to derive it from AZURE_OPENAI_ENDPOINT via Azure Resource Graph.
# Required if the endpoint host doesn't match the account name (e.g. APIM).
# AZURE_OPENAI_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>

# --- ACA Sandboxes (required) ---------------------------------------------

AZURE_SUBSCRIPTION_ID=<your-sub-id>
ACA_RESOURCE_GROUP=<your-rg>
ACA_SANDBOXGROUP_REGION=westus2
