{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "sandboxRegion": {
      "value": "${ACA_SANDBOX_REGION=westus2}"
    },
    "receiverImage": {
      "value": "${RECEIVER_IMAGE=mcr.microsoft.com/k8se/quickstart:latest}"
    }
  }
}
