# ACA sandbox group (per-machine; also discoverable from `aca config show`)
ACA_SUBSCRIPTION=00000000-0000-0000-0000-000000000000
ACA_RESOURCE_GROUP=ai-apps-samples-rg
ACA_SANDBOX_GROUP=ai-apps-samples-group
ACA_REGION=westus2

# Azure OpenAI deployment used by the demo's SandboxAgent
# Example: APIM gateway endpoint
AZURE_OPENAI_ENDPOINT=https://<your-apim-or-openai-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_API_KEY=<your-subscription-key-here>
